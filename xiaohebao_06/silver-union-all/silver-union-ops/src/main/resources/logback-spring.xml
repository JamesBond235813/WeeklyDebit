<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />
    <!-- 获取 application.yml / bootstrap.yml 中的配置-->
    <springProperty scope="context" name="BIZ_LOG_PATH" source="logging.pathPrefix"/>
    <springProperty scope="context" name="LOG_FILE_NAME" source="spring.application.name"/>
    <springProperty scope="context" name="LOG_LEVEL" source="logging.level.root"/>

    <!-- 日志格式及保存时间 -->
    <property name="MAX_HISTORY" value="93"/>
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [tid: %X{traceId:-} ] [%thread] %-5level %logger{30}:%L - %msg%n"/>

    <!--web信息-->
    <logger name="org.springframework.web" level="info"/>
    <appender name="CONSOLE_APPENDER" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- 日志文件的appender -->
    <appender name="FILE_APPENDER" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${BIZ_LOG_PATH}/${LOG_FILE_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${BIZ_LOG_PATH}/${LOG_FILE_NAME}.log.%d{yyyy-MM-dd}</fileNamePattern>
            <maxHistory>${MAX_HISTORY}</maxHistory>
        </rollingPolicy>
        <layout class="ch.qos.logback.classic.PatternLayout">
            <Pattern>${LOG_PATTERN}</Pattern>
        </layout>
<!--        <layout class="org.apache.skywalking.apm.toolkit.log.logback.v1.x.TraceIdPatternLogbackLayout">-->
<!--            <Pattern>${LOG_PATTERN}</Pattern>-->
<!--        </layout>-->
    </appender>
    <logger name="jdbc.resultsettable" level="OFF"/>
    <logger name="jdbc.sqlonly" level="OFF"/>
    <logger name="jdbc.audit" level="OFF"/>
    <logger name="jdbc.resultset" level="OFF"/>
    <logger name="jdbc.connection" level="OFF"/>
    <logger name="com.netflix.discovery" level="WARN"/>
    <logger name="log4jdbc" level="info"/>
    <logger name="org.apache.http" level="info"/>
    <logger name="org.springframework" level="info"/>
    <logger name="druid.sql.Connection" level="warn"/>
    <logger name="org.mybatis" level="warn"/>
    <logger name="io.netty" level="warn"/>
    <logger name="io.lettuce" level="warn"/>
    <logger name="com.netflix" level="warn"/>
    <logger name="springfox" level="warn"/>
    <logger name="com.alibaba.nacos" level="warn"/>
    <logger name="com.alibaba.cloud.nacos" level="warn"/>
    <logger name="org.redisson" level="warn"/>
    <logger name="org.redisson.connection" level="warn"/>
    <logger name="com.zaxxer.hikari.pool" level="warn"/>

    <springProfile name="prod">
        <root level="${LOG_LEVEL}">
            <appender-ref ref="FILE_APPENDER"/>
        </root>
    </springProfile>


    <root level="${LOG_LEVEL}">
        <appender-ref ref="CONSOLE_APPENDER"/>
        <appender-ref ref="FILE_APPENDER"/>
    </root>


</configuration>
